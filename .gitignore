/.obsidian
.DS_Store
.qoder/repowiki/zh/content/项目概述.md
.qoder/repowiki/zh/meta/repowiki-metadata.json

# ====================================================================
# 体育教培管理系统 - 统一 .gitignore 文件
# ====================================================================

# --- 操作系统与编辑器 ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- 后端 (Spring Boot / Maven) ---
target/
!.mvn/wrapper/maven-wrapper.jar
*.class
*.log
*.gz

# 配置文件（包含数据库密码、API Key 等敏感信息，建议本地配置）
src/main/resources/application-local.properties
src/main/resources/application-prod.properties
# 如果使用 Spring AI，隐藏你的 API Key 配置文件
src/main/resources/ai-config.yaml

# --- 前端 (uniapp / Vue 3 / Vite) ---
node_modules/
dist/
dev/
unpackage/
.env.local
.env.*.local

# 微信小程序特定
project.config.json
# 如果你希望保留项目配置，可以注释掉上面这一行，但请确保不包含私密 AppID

# --- AI 开发工具生成 (Claude/Cursor) ---
.claudecode/
.cursorrules
# 记录 AI 历史或状态的临时文件
.windsurf/

# --- 数据库与日志 ---
*.sql.gz
dump.rdb
logs/
*.log.1